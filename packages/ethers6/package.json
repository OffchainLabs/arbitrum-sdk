{
  "name": "@arbitrum/ethers6",
  "version": "0.1.0",
  "description": "Ethers v6 adapter for Arbitrum SDK - use ethers v6 types directly",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/OffchainLabs/arbitrum-sdk.git",
    "directory": "packages/ethers6"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist", "package.json", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "echo 'lint not configured yet'",
    "format": "echo 'format not configured yet'"
  },
  "dependencies": {
    "@arbitrum/core": "workspace:*"
  },
  "peerDependencies": {
    "ethers": "^6.0.0"
  },
  "devDependencies": {
    "ethers": "^6.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.1"
  }
}
