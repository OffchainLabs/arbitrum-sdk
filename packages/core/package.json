{
  "name": "@arbitrum/core",
  "version": "0.1.0",
  "description": "Provider-agnostic core library for Arbitrum SDK",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/OffchainLabs/arbitrum-sdk.git",
    "directory": "packages/core"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
